# Aplicação
APP_NAME=Assistente Acadêmico Local
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=academic
POSTGRES_PASSWORD=academic_secret
POSTGRES_DB=academic_assistant

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=60

# Coletor
COLLECTOR_INTERVAL_SECONDS=30
COLLECTOR_LOCATION_NAME=Campus Central
COLLECTOR_LATITUDE=-23.5505
COLLECTOR_LONGITUDE=-46.6333

# Fonte de dados
DATA_SOURCE_NAME=Open-Meteo (Simulação Acadêmica)
DATA_SOURCE_TYPE=api
DATA_SOURCE_BASE_URL=https://api.open-meteo.com/v1

# API
API_HOST=0.0.0.0
API_PORT=8000

# Agente IA (mock | ollama | openai)
LLM_PROVIDER=mock
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
RAG_TOP_K=10
